# Storage provider: "static" (local/file-based) or "server" (Docker backend API)
VITE_STORAGE=static
# When VITE_STORAGE=static, set this to auto-load a map file on startup.
# If not set, the editor starts with an empty map.
# VITE_MAP_FILE=/maps/canary.otbm

# Docker: UID/GID for the container process (avoids root-owned files in mounted volumes)
# UID=1000
# GID=1000
